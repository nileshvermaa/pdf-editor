# Copy this to .env.local for local overrides.
# In development, the Vite proxy handles /api → localhost:8000 automatically.
# Set this env var in the Vercel dashboard (not .env files) for production.

# Your Render backend URL — copy from the Render service dashboard.
# Format: https://<service-name>.onrender.com/api  (no trailing slash)
VITE_API_BASE=https://your-backend.onrender.com/api
